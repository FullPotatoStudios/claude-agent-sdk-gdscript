static func sanitize(value: String) -> String:
	var current := value
	for _i in range(MAX_PASSES):
		var next := ""
		for j in range(current.length()):
			var code := current.unicode_at(j)
			if _should_strip_codepoint(code):
				continue
			if NFKC_SINGLE_CODEPOINT_MAP.has(code):
				next += str(NFKC_SINGLE_CODEPOINT_MAP[code])
			else:
				next += char(code)
		if next == current:
			return next
		current = next
	return current


static func _should_strip_codepoint(code: int) -> bool:
	for i in range(0, STRIP_RANGES.size(), 2):
		var range_start := int(STRIP_RANGES[i])
		if code < range_start:
			return false
		var range_end := int(STRIP_RANGES[i + 1])
		if code <= range_end:
			return true
	return false
