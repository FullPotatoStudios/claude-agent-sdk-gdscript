const HANGUL_S_BASE := 44032
const HANGUL_L_BASE := 4352
const HANGUL_V_BASE := 4449
const HANGUL_T_BASE := 4519
const HANGUL_L_COUNT := 19
const HANGUL_V_COUNT := 21
const HANGUL_T_COUNT := 28
const HANGUL_S_COUNT := 11172


static func sanitize(value: String) -> String:
	var current := value
	for _i in range(MAX_PASSES):
		var previous := current
		current = _normalize_nfkc(previous)
		current = _strip_disallowed_codepoints(current)
		if current == previous:
			break
	return current


static func _normalize_nfkc(value: String) -> String:
	var decomposed: Array[int] = []
	for i in range(value.length()):
		var code := value.unicode_at(i)
		if NFKD_DECOMPOSITION_MAP.has(code):
			var decomposition := str(NFKD_DECOMPOSITION_MAP[code])
			for j in range(decomposition.length()):
				decomposed.append(decomposition.unicode_at(j))
		else:
			decomposed.append(code)
	var ordered := _reorder_combining_marks(decomposed)
	return _compose_canonical(ordered)


static func _reorder_combining_marks(codepoints: Array[int]) -> Array[int]:
	var ordered: Array[int] = []
	for code in codepoints:
		ordered.append(code)
		var code_class := _combining_class(code)
		if code_class == 0:
			continue
		var index := ordered.size() - 1
		while index > 0:
			var previous_class := _combining_class(int(ordered[index - 1]))
			if previous_class == 0 or previous_class <= code_class:
				break
			var previous_code := int(ordered[index - 1])
			ordered[index - 1] = int(ordered[index])
			ordered[index] = previous_code
			index -= 1
	return ordered


static func _compose_canonical(codepoints: Array[int]) -> String:
	if codepoints.is_empty():
		return ""
	var composed: Array[int] = [int(codepoints[0])]
	var starter_index := 0
	var starter := int(composed[0])
	var last_class := 0
	for i in range(1, codepoints.size()):
		var code := int(codepoints[i])
		var code_class := _combining_class(code)
		var composite := _compose_pair(starter, code)
		if composite >= 0 and (last_class < code_class or last_class == 0):
			composed[starter_index] = composite
			starter = composite
			continue
		if code_class == 0:
			starter_index = composed.size()
			starter = code
			last_class = 0
		else:
			last_class = code_class
		composed.append(code)
	var text := ""
	for code in composed:
		text += char(code)
	return text


static func _compose_pair(starter: int, code: int) -> int:
	if starter >= HANGUL_L_BASE and starter < HANGUL_L_BASE + HANGUL_L_COUNT:
		if code >= HANGUL_V_BASE and code < HANGUL_V_BASE + HANGUL_V_COUNT:
			return HANGUL_S_BASE + ((starter - HANGUL_L_BASE) * HANGUL_V_COUNT + (code - HANGUL_V_BASE)) * HANGUL_T_COUNT
	if starter >= HANGUL_S_BASE and starter < HANGUL_S_BASE + HANGUL_S_COUNT:
		if (starter - HANGUL_S_BASE) % HANGUL_T_COUNT == 0 and code > HANGUL_T_BASE and code < HANGUL_T_BASE + HANGUL_T_COUNT:
			return starter + (code - HANGUL_T_BASE)
	if CANONICAL_COMPOSITION_MAP.has(starter):
		var trailing_map: Dictionary = CANONICAL_COMPOSITION_MAP[starter]
		if trailing_map.has(code):
			return int(trailing_map[code])
	return -1


static func _combining_class(code: int) -> int:
	if NON_ZERO_COMBINING_CLASSES.has(code):
		return int(NON_ZERO_COMBINING_CLASSES[code])
	return 0


static func _strip_disallowed_codepoints(value: String) -> String:
	var next := ""
	for j in range(value.length()):
		var code := value.unicode_at(j)
		if _should_strip_codepoint(code):
			continue
		next += char(code)
	return next


static func _should_strip_codepoint(code: int) -> bool:
	for i in range(0, STRIP_RANGES.size(), 2):
		var range_start := int(STRIP_RANGES[i])
		if code < range_start:
			return false
		var range_end := int(STRIP_RANGES[i + 1])
		if code <= range_end:
			return true
	return false
